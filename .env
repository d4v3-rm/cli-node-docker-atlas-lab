# ------------------------------------------------------------------------------
# Gateway ingress and network identity
# ------------------------------------------------------------------------------
LAB_HTTPS_PORT=8443
LAB_GATEWAY_IP=127.0.0.1
LAB_LOCAL_HOST=localhost
LAB_CANONICAL_HOST=lab.home.arpa
LAB_LOCAL_URL=https://localhost:8443/
LAB_URL=https://lab.home.arpa:8443/
TZ=Europe/Rome

# ------------------------------------------------------------------------------
# Gateway TLS and image versions
# ------------------------------------------------------------------------------
SSL_CERT_AUTOGEN=1
SSL_CERT_CN=lab.home.arpa
SSL_CERT_DAYS=825
CADDY_VERSION=2.10.2-alpine
GITEA_VERSION=1.25.3
GITEA_DB_VERSION=11.4
N8N_VERSION=2.2.6
OPENWEBUI_VERSION=v0.8.8
OLLAMA_VERSION=0.13.5
POSTGRES_DEV_VERSION=16.11

# ------------------------------------------------------------------------------
# Service hostnames and public URLs
# ------------------------------------------------------------------------------
GITEA_HOST=gitea.lab.home.arpa
GITEA_URL=https://gitea.lab.home.arpa:8443/
N8N_HOST=n8n.lab.home.arpa
N8N_URL=https://n8n.lab.home.arpa:8443/
OPENWEBUI_HOST=webui.lab.home.arpa
OPENWEBUI_URL=https://webui.lab.home.arpa:8443/
OLLAMA_HOST=ollama.lab.home.arpa
OLLAMA_URL=https://ollama.lab.home.arpa:8443/
NODE_DEV_HOST=node.lab.home.arpa
NODE_DEV_URL=https://node.lab.home.arpa:8443/
PYTHON_DEV_HOST=python.lab.home.arpa
PYTHON_DEV_URL=https://python.lab.home.arpa:8443/
AI_DEV_HOST=ai.lab.home.arpa
AI_DEV_URL=https://ai.lab.home.arpa:8443/
CPP_DEV_HOST=cpp.lab.home.arpa
CPP_DEV_URL=https://cpp.lab.home.arpa:8443/

# ------------------------------------------------------------------------------
# Gitea
# ------------------------------------------------------------------------------
GITEA_UID=1000
GITEA_GID=1000
GITEA_DB_PASSWORD=gitea-db-pass
GITEA_DB_ROOT_PASSWORD=gitea-db-root-pass
GITEA_ROOT_USERNAME=root
GITEA_ROOT_PASSWORD=RootGitea!2026
GITEA_ROOT_EMAIL=root@gitea.lab.home.arpa

# ------------------------------------------------------------------------------
# n8n
# ------------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=n8n-encryption-key-lab-2026
N8N_RUNNERS_AUTH_TOKEN=n8n-runners-auth-token-2026
N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT=15
N8N_GATEWAY_USER=root
N8N_GATEWAY_PASSWORD=RootN8N!2026
N8N_ROOT_FIRST_NAME=Root
N8N_ROOT_LAST_NAME=Automation
N8N_ROOT_EMAIL=root@n8n.lab.home.arpa
N8N_ROOT_PASSWORD=RootN8NApp!2026

# ------------------------------------------------------------------------------
# Open WebUI
# ------------------------------------------------------------------------------
OPENWEBUI_ROOT_NAME=Root Operator
OPENWEBUI_ROOT_EMAIL=root@webui.lab.home.arpa
OPENWEBUI_ROOT_PASSWORD=RootOpenWebUI!2026
OPENWEBUI_SECRET_KEY=open-webui-secret-key-lab-2026
OPENWEBUI_CORS_ALLOW_ORIGIN=https://webui.lab.home.arpa:8443;https://localhost:8443;https://lab.home.arpa:8443

# ------------------------------------------------------------------------------
# Ollama
# ------------------------------------------------------------------------------
OLLAMA_GATEWAY_USER=root
OLLAMA_GATEWAY_PASSWORD=RootOllama!2026
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------------------------
# PostgreSQL development server
# ------------------------------------------------------------------------------
POSTGRES_DEV_SUPERUSER=postgres
POSTGRES_DEV_PASSWORD=RootPostgresDev!2026
POSTGRES_DEV_DATABASE=lab

# ------------------------------------------------------------------------------
# Node development environment
# ------------------------------------------------------------------------------
NODE_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.109.5
NODE_DEV_NODE_VERSION=20.15.1
NODE_DEV_PNPM_VERSION=9.12.3
NODE_DEV_YARN_VERSION=1.22.22
NODE_DEV_INSTALL_PACKAGES=postgresql-client
NODE_DEV_PASSWORD=RootNodeDev!2026
NODE_DEV_AUTH=password
NODE_DEV_EXTENSIONS=
NODE_DEV_GLOBAL_PACKAGES=

# ------------------------------------------------------------------------------
# Python development environment
# ------------------------------------------------------------------------------
PYTHON_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.109.5
PYTHON_DEV_PYTHON_VERSION=3.12.5
PYTHON_DEV_INSTALL_PACKAGES=postgresql-client
PYTHON_DEV_PIP_PACKAGES=
PYTHON_DEV_PIP_INDEX_URL=
PYTHON_DEV_PIP_EXTRA_INDEX_URL=
PYTHON_DEV_PASSWORD=RootPythonDev!2026
PYTHON_DEV_AUTH=password
PYTHON_DEV_EXTENSIONS=
PYTHON_DEV_RUNTIME_PIP_PACKAGES=

# ------------------------------------------------------------------------------
# AI development environment
# ------------------------------------------------------------------------------
AI_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.109.5
AI_DEV_PYTHON_VERSION=3.12.5
AI_DEV_INSTALL_PACKAGES=postgresql-client
AI_DEV_PIP_PACKAGES=numpy pandas scikit-learn matplotlib seaborn jupyterlab ipykernel transformers accelerate
AI_DEV_PIP_INDEX_URL=
AI_DEV_PIP_EXTRA_INDEX_URL=
AI_DEV_PASSWORD=RootAIDev!2026
AI_DEV_AUTH=password
AI_DEV_EXTENSIONS=
AI_DEV_RUNTIME_PIP_PACKAGES=

# ------------------------------------------------------------------------------
# C++ development environment
# ------------------------------------------------------------------------------
CPP_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.109.5
CPP_DEV_PACKAGES=build-essential cmake ninja-build gdb clang lldb lld
CPP_DEV_INSTALL_PACKAGES=postgresql-client
CPP_DEV_PASSWORD=RootCppDev!2026
CPP_DEV_AUTH=password
CPP_DEV_EXTENSIONS=
