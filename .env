# ------------------------------------------------------------------------------
# Gateway
# ------------------------------------------------------------------------------
LAB_HTTP_PORT=8080
LAB_HTTPS_PORT=8443
LAB_EXTERNAL_URL=https://localhost:8443
LAB_DOMAIN=localhost
TZ=Europe/Rome

# ------------------------------------------------------------------------------
# HTTPS self-signed certificate
# ------------------------------------------------------------------------------
SSL_CERT_AUTOGEN=1
SSL_CERT_CN=localhost
SSL_CERT_SAN=DNS:localhost,DNS:lab.local
SSL_CERT_DAYS=365

# ------------------------------------------------------------------------------
# Gitea
# ------------------------------------------------------------------------------
GITEA_VERSION=1.22.1
GITEA_UID=1000
GITEA_GID=1000
GITEA_DB_PASSWORD=gitea-db-pass
GITEA_DB_ROOT_PASSWORD=gitea-db-root-pass
GITEA_ROOT_USERNAME=root
GITEA_ROOT_PASSWORD=RootGitea!2026
GITEA_ROOT_EMAIL=root@gitea.local

# ------------------------------------------------------------------------------
# n8n
# ------------------------------------------------------------------------------
N8N_VERSION=latest
N8N_ENCRYPTION_KEY=n8n-encryption-key-lab-2026
N8N_GATEWAY_USER=root
N8N_GATEWAY_PASSWORD=RootN8N!2026
N8N_ROOT_FIRST_NAME=Root
N8N_ROOT_LAST_NAME=Automation
N8N_ROOT_EMAIL=root@n8n.local
N8N_ROOT_PASSWORD=RootN8NApp!2026

# ------------------------------------------------------------------------------
# Open WebUI
# ------------------------------------------------------------------------------
OPENWEBUI_VERSION=main
OPENWEBUI_ROOT_NAME=Root Operator
OPENWEBUI_ROOT_EMAIL=root@openwebui.local
OPENWEBUI_ROOT_PASSWORD=RootOpenWebUI!2026

# ------------------------------------------------------------------------------
# Ollama
