{
  "name": "cli-node-docker-atlas-lab",
  "version": "1.0.0",
  "description": "Node.js CLI for the Atlas Lab local stack",
  "type": "module",
  "bin": {
    "atlas-lab": "./bin/atlas-lab"
  },
  "scripts": {
    "dev": "tsx ./src/bin/atlas-lab.ts",
    "build": "tsup",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pack:local": "npm pack"
  },
  "files": [
    ".dockerignore",
    "apps/lab-index",
    "bin",
    "config",
    "dist",
    "infra/docker",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "dotenv": "^17.2.3",
    "execa": "^9.6.0",
    "find-up": "^8.0.0",
    "got": "^14.6.1",
    "listr2": "^9.0.4",
    "log-symbols": "^7.0.1",
    "p-wait-for": "^6.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
