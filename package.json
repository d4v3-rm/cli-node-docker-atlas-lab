{
  "name": "cli-node-docker-atlas-lab",
  "version": "1.0.0",
  "description": "Node.js CLI for the Atlas Lab local stack",
  "type": "module",
  "bin": {
    "atlas-lab": "./bin/atlas-lab"
  },
  "scripts": {
    "dev": "tsx ./src/bin/atlas-lab.ts",
    "build": "tsup",
    "dev:lab-index": "vite --config ./lab-index.vite.config.ts",
    "build:lab-index": "tsc -p ./tsconfig.lab-index.json --noEmit && vite build --config ./lab-index.vite.config.ts",
    "typecheck:lab-index": "tsc -p ./tsconfig.lab-index.json --noEmit",
    "preview:lab-index": "vite preview --config ./lab-index.vite.config.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pack:local": "npm pack"
  },
  "files": [
    ".dockerignore",
    "apps/lab-index",
    "bin",
    "config",
    "dist",
    "infra/docker",
    "lab-index.vite.config.ts",
    "README.md",
    "tsconfig.lab-index.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "dotenv": "^17.2.3",
    "execa": "^9.6.0",
    "find-up": "^8.0.0",
    "got": "^14.6.1",
    "listr2": "^9.0.4",
    "log-symbols": "^7.0.1",
    "p-wait-for": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
