    <div class="modal-shell" id="modal-shell" aria-hidden="true">
      <div class="modal">
        <div class="modal-header">
          <h3 id="modal-title">Briefing</h3>
          <button class="modal-close" type="button" id="modal-close" aria-label="Chiudi">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <div class="modal-body" id="modal-body"></div>
      </div>
