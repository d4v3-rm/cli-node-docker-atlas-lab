    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.7/dist/purify.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
    <script>
      (function () {
        var hero = document.querySelector(".hero");
        var revealItems = document.querySelectorAll(
          ".aside-card, .service-card, .workbench-card, .footer-card"
        );
        var statValues = document.querySelectorAll(".stat-value");

        gsap.from(".hero", {
          duration: 1.1,
          y: 24,
          opacity: 0,
          ease: "power3.out",
        });

        gsap.from(".eyebrow, .headline, .hero-copy, .pill, .stat", {
          duration: 0.9,
          y: 18,
          opacity: 0,
          stagger: 0.08,
          delay: 0.12,
          ease: "power2.out",
        });

        gsap.set(revealItems, { opacity: 0, y: 28 });

        var revealObserver = new IntersectionObserver(
          function (entries, observer) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) {
                return;
              }

              gsap.to(entry.target, {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: "power3.out",
              });
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.14 }
        );

        revealItems.forEach(function (item) {
          revealObserver.observe(item);
        });

        var statsAnimated = false;

        function animateStats() {
          if (statsAnimated) {
            return;
          }

          statsAnimated = true;
          statValues.forEach(function (node) {
            var target = parseInt(node.textContent, 10);
            var counter = { value: 0 };

            gsap.to(counter, {
              value: target,
              duration: 1.2,
              ease: "power2.out",
              onUpdate: function () {
                node.textContent = Math.round(counter.value).toString();
              },
            });
          });
        }

        var statsObserver = new IntersectionObserver(
          function (entries, observer) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) {
                return;
              }

              animateStats();
              observer.disconnect();
            });
          },
          { threshold: 0.4 }
        );

        if (document.querySelector(".stat-grid")) {
          statsObserver.observe(document.querySelector(".stat-grid"));
        }

        if (hero) {
          hero.addEventListener("pointermove", function (event) {
            var rect = hero.getBoundingClientRect();
            var offsetX = (event.clientX - rect.left) / rect.width - 0.5;
            var offsetY = (event.clientY - rect.top) / rect.height - 0.5;

            hero.style.setProperty("--glow-x", 50 + offsetX * 18 + "%");
            hero.style.setProperty("--glow-y", 38 + offsetY * 14 + "%");
          });

          hero.addEventListener("pointerleave", function () {
            hero.style.setProperty("--glow-x", "50%");
            hero.style.setProperty("--glow-y", "38%");
          });
        }

        var modalShell = document.getElementById("modal-shell");
        var modalTitle = document.getElementById("modal-title");
        var modalBody = document.getElementById("modal-body");
        var modalClose = document.getElementById("modal-close");
        var markdownButtons = document.querySelectorAll("[data-markdown]");

        function closeModal() {
          modalShell.classList.remove("active");
          modalShell.setAttribute("aria-hidden", "true");
          modalBody.innerHTML = "";
        }

        async function openMarkdown(event) {
          var button = event.currentTarget;
          var markdownPath = button.getAttribute("data-markdown");
          var title = button.getAttribute("data-title") || "Briefing";

          modalTitle.textContent = title;
          modalBody.innerHTML = "<p>Caricamento briefing locale...</p>";
          modalShell.classList.add("active");
          modalShell.setAttribute("aria-hidden", "false");

          try {
            var response = await fetch(markdownPath, { cache: "no-store" });
            if (!response.ok) {
              throw new Error("HTTP " + response.status);
            }

            var markdown = await response.text();
            var html = marked.parse(markdown);
            modalBody.innerHTML = DOMPurify.sanitize(html);
          } catch (error) {
            modalBody.innerHTML =
              "<p>Impossibile caricare il briefing locale.</p><pre><code>" +
              DOMPurify.sanitize(String(error)) +
              "</code></pre>";
          }
        }

        markdownButtons.forEach(function (button) {
          button.addEventListener("click", openMarkdown);
        });

        modalClose.addEventListener("click", closeModal);
        modalShell.addEventListener("click", function (event) {
          if (event.target === modalShell) {
            closeModal();
          }
        });

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape") {
            closeModal();
          }
        });
      })();
    </script>
  </body>
