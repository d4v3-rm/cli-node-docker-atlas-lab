<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#111317" />
    <title>Lab Atlas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <style>
      :root {
        --bg: #111317;
        --bg-soft: rgba(17, 19, 23, 0.88);
        --ink: #f6f1e9;
        --ink-soft: #cdc3b6;
        --panel: #f3eee7;
        --panel-strong: #fcf8f1;
        --text: #16171b;
        --muted: #62625f;
        --accent: #365a86;
        --accent-soft: #7d91aa;
        --gold: #a77743;
        --line-dark: rgba(255, 255, 255, 0.12);
        --line-light: rgba(17, 19, 23, 0.1);
        --shadow: 0 32px 90px rgba(0, 0, 0, 0.28);
        --shadow-soft: 0 18px 42px rgba(0, 0, 0, 0.14);
        --glow-x: 50%;
        --glow-y: 38%;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 0%, rgba(167, 119, 67, 0.26), transparent 26%),
          radial-gradient(circle at 88% 12%, rgba(54, 90, 134, 0.2), transparent 24%),
          linear-gradient(180deg, #15181e 0%, #1a1d24 42%, #111317 100%);
        font-family: "Manrope", sans-serif;
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      body::before {
        background:
          linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 92px 92px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.92), transparent 88%);
        opacity: 0.22;
        animation: grid-drift 30s linear infinite;
      }

      body::after {
        background: radial-gradient(circle at center, rgba(255, 255, 255, 0.14), transparent 60%);
        opacity: 0.34;
        animation: pulse-field 16s ease-in-out infinite;
      }

      @keyframes grid-drift {
        from {
          transform: translate3d(0, 0, 0);
        }
        to {
          transform: translate3d(92px, 92px, 0);
        }
      }

      @keyframes pulse-field {
        0%,
        100% {
          transform: scale(1);
          opacity: 0.28;
        }
        50% {
          transform: scale(1.06);
          opacity: 0.4;
        }
      }

      .backdrop-orb {
        position: fixed;
        width: 34rem;
        height: 34rem;
        border-radius: 12%;
        filter: blur(8px);
        opacity: 0.2;
        pointer-events: none;
        z-index: 0;
        animation: slab-drift 18s ease-in-out infinite;
      }

      .backdrop-orb.left {
        top: -10rem;
        left: -8rem;
        background:
          radial-gradient(circle at 20% 20%, rgba(255, 250, 242, 0.32), transparent 24%),
          linear-gradient(135deg, rgba(167, 119, 67, 0.22), transparent 68%);
        transform: rotate(-16deg);
      }

      .backdrop-orb.right {
        right: -10rem;
        bottom: -12rem;
        background:
          radial-gradient(circle at 70% 30%, rgba(255, 255, 255, 0.2), transparent 26%),
          linear-gradient(135deg, rgba(54, 90, 134, 0.28), transparent 70%);
        transform: rotate(18deg);
        animation-delay: -8s;
      }

      @keyframes slab-drift {
        0%,
        100% {
          transform: translate3d(0, 0, 0) rotate(-12deg);
        }
        50% {
          transform: translate3d(18px, -24px, 0) rotate(-6deg);
        }
      }

      .deck {
        position: relative;
        z-index: 1;
        width: min(1400px, calc(100% - 40px));
        margin: 24px auto 64px;
      }

      .hero,
      .service-card,
      .workbench-card,
      .footer-card,
      .modal {
        box-shadow: var(--shadow);
      }

      .hero {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--line-dark);
        border-radius: 12px;
        padding: 36px;
        background:
          radial-gradient(circle at var(--glow-x) var(--glow-y), rgba(255, 255, 255, 0.12), transparent 24%),
          linear-gradient(140deg, rgba(255, 255, 255, 0.08), transparent 42%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01)),
          var(--bg-soft);
        backdrop-filter: blur(14px);
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.08) 48%, transparent 100%);
        transform: skewX(-20deg) translateX(-130%);
        animation: scan 10s linear infinite;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 22px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        pointer-events: none;
      }

      @keyframes scan {
        to {
          transform: skewX(-24deg) translateX(220%);
        }
      }

      .eyebrow,
      .section-tag,
      .pill,
      .service-status,
      .button,
      .ghost-button {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .eyebrow,
      .section-tag {
        border: 1px solid var(--line-dark);
        border-radius: 6px;
        padding: 10px 14px;
        color: var(--ink);
        letter-spacing: 0.18em;
        font-size: 0.74rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.04);
      }

      .hero-grid,
      .stat-grid,
      .service-grid,
      .workbench-grid,
      .footer-bar {
        display: grid;
        gap: 18px;
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
        align-items: end;
        margin-top: 18px;
      }

      .headline,
      .section-header h2,
      .service-card h3,
      .workbench-card h3,
      .aside-title,
      .modal-header h3,
      .modal-body h1,
      .modal-body h2,
      .modal-body h3 {
        font-family: "Sora", sans-serif;
        text-transform: uppercase;
      }

      .headline {
        margin: 18px 0 14px;
        font-size: clamp(3rem, 8vw, 6rem);
        line-height: 0.84;
        letter-spacing: 0.08em;
        max-width: 8ch;
      }

      .headline span,
      .stat-value {
        color: #ffffff;
      }

      .headline span {
        display: block;
      }

      .hero-copy,
      .section-header p,
      .service-card p,
      .workbench-card p,
      .aside-meta,
      .footer-card span,
      .modal-body p,
      .modal-body li {
        color: var(--ink-soft);
      }

      .hero-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 24px;
      }

      .hero-copy {
        max-width: 46rem;
        font-size: 1.08rem;
        line-height: 1.66;
      }

      .hero-aside {
        display: grid;
        gap: 14px;
      }

      .pill {
        border-radius: 6px;
        padding: 10px 12px;
        border: 1px solid var(--line-dark);
        background: rgba(255, 255, 255, 0.03);
        font-size: 0.76rem;
        font-weight: 700;
      }

      .aside-card,
      .service-card,
      .workbench-card,
      .footer-card {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid var(--line-light);
        padding: 20px;
      }

      .aside-card {
        border-color: rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
      }

      .footer-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.96)),
          var(--panel);
        box-shadow: var(--shadow-soft);
      }

      .aside-title {
        margin: 0 0 10px;
        font-size: 0.88rem;
        letter-spacing: 0.18em;
        color: #efe1cd;
      }

      .aside-meta {
        display: grid;
        gap: 10px;
      }

      .stat-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 24px;
      }

      .stat {
        border-radius: 8px;
        padding: 18px;
        border: 1px solid var(--line-dark);
        background: rgba(255, 255, 255, 0.03);
      }

      .stat-value {
        font-size: clamp(1.8rem, 4vw, 2.9rem);
      }

      .stat-label {
        color: rgba(255, 255, 255, 0.64);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.74rem;
        font-weight: 700;
      }

      .section {
        margin-top: 34px;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 18px;
      }

      .section-header h2 {
        margin: 12px 0 0;
        font-size: clamp(1.9rem, 4vw, 3rem);
        letter-spacing: 0.08em;
        color: var(--ink);
      }

      .section-header p {
        max-width: 46rem;
      }

      .service-grid,
      .workbench-grid {
        grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
        gap: 20px;
      }

      .service-card,
      .workbench-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.96)),
          var(--panel);
        padding: 24px;
        box-shadow: var(--shadow-soft);
      }

      .service-card::before,
      .workbench-card::before,
      .aside-card::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
      }

      .service-card::before,
      .workbench-card::before {
        background:
          linear-gradient(180deg, rgba(54, 90, 134, 0.06), transparent 24%),
          linear-gradient(90deg, rgba(167, 119, 67, 0.16), transparent 32%, rgba(54, 90, 134, 0.09) 78%);
        mix-blend-mode: multiply;
      }

      .aside-card::after {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent 54%);
      }

      .service-top,
      .workbench-top,
      .card-actions,
      .credential-grid {
        position: relative;
      }

      .service-top,
      .workbench-top {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 16px;
      }

      .icon-box {
        width: 56px;
        height: 56px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        border: 1px solid rgba(17, 19, 23, 0.08);
        background: linear-gradient(180deg, #f9f5ee, #ece3d8);
        color: var(--accent);
        font-size: 1.3rem;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
      }

      .service-status {
        border-radius: 6px;
        padding: 7px 10px;
        font-size: 0.72rem;
        font-weight: 800;
        background: rgba(17, 19, 23, 0.04);
        color: var(--text);
        border: 1px solid rgba(17, 19, 23, 0.08);
      }

      .service-card h3,
      .workbench-card h3 {
        position: relative;
        margin: 18px 0 10px;
        font-size: 1.25rem;
        letter-spacing: 0.08em;
        color: var(--text);
      }

      .service-card p,
      .workbench-card p,
      .footer-card span,
      .modal-body p,
      .modal-body li {
        color: var(--muted);
        line-height: 1.62;
      }

      .credential-grid {
        display: grid;
        gap: 10px;
        margin: 18px 0 20px;
      }

      .credential {
        display: grid;
        grid-template-columns: minmax(96px, 132px) minmax(0, 1fr);
        align-items: start;
        gap: 12px 16px;
        padding: 12px 14px;
        border-radius: 6px;
        border: 1px solid rgba(17, 19, 23, 0.08);
        background: rgba(17, 19, 23, 0.03);
        font-size: 0.95rem;
      }

      .credential span:first-child {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        font-weight: 700;
      }

      .credential span:last-child,
      .modal-body code {
        color: var(--text);
        font-family: "Consolas", "SFMono-Regular", monospace;
        text-align: left;
        min-width: 0;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .button,
      .ghost-button {
        justify-content: center;
        border-radius: 6px;
        padding: 13px 18px;
        font-family: "Sora", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease,
          background-color 0.22s ease;
      }

      .card-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .button {
        color: var(--panel-strong);
        background: linear-gradient(180deg, #1b2432, #12171f);
        border: 1px solid rgba(255, 255, 255, 0.08);
        text-decoration: none;
        box-shadow: 0 14px 28px rgba(0, 0, 0, 0.18);
      }

      .ghost-button {
        color: var(--text);
        background: #ebe2d7;
        border: 1px solid rgba(17, 19, 23, 0.08);
      }

      .button:hover,
      .ghost-button:hover {
        transform: translateY(-3px);
      }

      .service-note {
        position: relative;
        margin-top: 16px;
        padding: 14px 16px;
        color: var(--text);
        background: rgba(167, 119, 67, 0.08);
        border-left: 3px solid rgba(167, 119, 67, 0.7);
      }

      .modal-shell {
        position: fixed;
        inset: 0;
        display: none;
        place-items: center;
        background: rgba(8, 10, 14, 0.78);
        backdrop-filter: blur(18px);
        z-index: 40;
        padding: 18px;
      }

      .modal-shell.active {
        display: grid;
      }

      .modal {
        width: min(920px, 100%);
        max-height: min(84vh, 920px);
        overflow: hidden;
        border-radius: 10px;
        border: 1px solid rgba(17, 19, 23, 0.12);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.98)),
          var(--panel-strong);
      }

      .modal-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        padding: 22px 24px;
        border-bottom: 1px solid rgba(17, 19, 23, 0.08);
      }

      .modal-header h3 {
        margin: 0;
        letter-spacing: 0.08em;
        color: var(--text);
      }

      .modal-body {
        overflow: auto;
        max-height: calc(84vh - 82px);
        padding: 26px 28px 30px;
        color: var(--text);
      }

      .modal-body code {
        padding: 0.18rem 0.4rem;
        border-radius: 4px;
        background: rgba(17, 19, 23, 0.06);
      }

      .modal-body pre {
        overflow: auto;
        border-radius: 8px;
        padding: 16px;
        border: 1px solid rgba(17, 19, 23, 0.08);
        background: rgba(17, 19, 23, 0.04);
      }

      .modal-close {
        width: 42px;
        height: 42px;
        border-radius: 6px;
        border: 1px solid rgba(17, 19, 23, 0.08);
        background: rgba(17, 19, 23, 0.04);
        color: var(--text);
        cursor: pointer;
      }

      .footer-bar {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-top: 30px;
      }

      .footer-card strong {
        display: block;
        margin-bottom: 8px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.74rem;
      }

      @media (max-width: 960px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }

        .stat-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .deck {
          width: min(100% - 20px, 1320px);
          margin-top: 12px;
        }

        .hero,
        .service-card,
        .workbench-card {
          border-radius: 8px;
          padding: 20px;
        }

        .headline {
          font-size: 2.8rem;
        }

        .credential {
          grid-template-columns: 1fr;
          gap: 6px;
        }
      }
    </style>
  </head>
  <body>
    <div class="backdrop-orb left"></div>
    <div class="backdrop-orb right"></div>

    <main class="deck">
      <section class="hero">
        <span class="eyebrow"><i class="fa-solid fa-compass-drafting"></i> atlas control index</span>
        <div class="hero-grid">
          <div>
            <h1 class="headline">
              LAB
              <span>ATLAS</span>
            </h1>
            <p class="hero-copy">
              Pannello operativo unificato per repository, automazione, AI locale e workbench
              opzionali. Il gateway Caddy espone ogni servizio sul proprio host dedicato e rende
              leggibili in un solo punto percorsi, credenziali root e funzione dei nodi attivi.
            </p>
            <div class="hero-strip">
              <span class="pill"><i class="fa-solid fa-link"></i> deck locale ${LAB_LOCAL_URL}</span>
              <span class="pill"><i class="fa-solid fa-lock"></i> ingress solo https</span>
              <span class="pill"><i class="fa-solid fa-earth-europe"></i> host canonico ${LAB_URL}</span>
              <span class="pill"><i class="fa-solid fa-database"></i> persistenza su volumi</span>
              <span class="pill"><i class="fa-solid fa-bars-progress"></i> accessi e root in chiaro</span>
              <span class="pill"><i class="fa-solid fa-diagram-next"></i> host separati, reti interne ed egress selettivo</span>
            </div>
            <div class="stat-grid">
              <div class="stat">
                <div class="stat-value">4</div>
                <div class="stat-label">servizi core</div>
              </div>
              <div class="stat">
                <div class="stat-value">5</div>
                <div class="stat-label">nodi workbench</div>
              </div>
              <div class="stat">
                <div class="stat-value">1</div>
                <div class="stat-label">gateway atlas</div>
              </div>
            </div>
          </div>
          <div class="hero-aside">
            <div class="aside-card">
              <p class="aside-title">operating charter</p>
              <div class="aside-meta">
                <span>Gitea governa codice, review e flusso Git interno.</span>
                <span>n8n orchestra webhook, automazioni e job operativi.</span>
                <span>Open WebUI e Ollama coprono interfaccia e inference locale per l'AI.</span>
                <span>I workbench code-server e Postgres restano su profilo dedicato e raggiungibili tramite briefing locale.</span>
              </div>
            </div>
            <div class="aside-card">
              <p class="aside-title">access notes</p>
              <div class="aside-meta">
                <span>Le credenziali root sono esposte qui e nel file <code>.env</code>.</span>
                <span>I servizi usano host dedicati: se non hai DNS interno, applica la mappa hosts locale.</span>
                <span>n8n resta protetto da gateway auth piu owner bootstrap applicativo.</span>
                <span>Ollama e servito come API locale dietro host separato e auth gateway.</span>
                <span>Postgres non ha UI pubblica e viene consumato soltanto dai workbench.</span>
                <span>I servizi core e i workbench hanno egress selettivo su reti dedicate, senza porte pubbliche aggiuntive.</span>
              </div>
              <div class="card-actions" style="margin-top: 16px">
                <button class="ghost-button" type="button" data-markdown="/content/network-map.md" data-title="Network Map">
                  <i class="fa-solid fa-network-wired"></i> apri network map
                </button>
                <a class="button" href="/assets/lab.crt" target="_blank" rel="noopener noreferrer">
                  <i class="fa-solid fa-certificate"></i> scarica certificato
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-tag"><i class="fa-solid fa-grid-2"></i> service catalog</span>
            <h2>Servizi Attivi</h2>
          </div>
          <p>
            Ogni card spiega il servizio, mostra le credenziali root e apre direttamente il target
            operativo sul proprio host dedicato. Le icone distinguono repository, automazione,
            interfacce AI e API modelli.
          </p>
        </div>

        <div class="service-grid">
          <article class="service-card">
            <div class="service-top">
              <div class="icon-box"><i class="fa-solid fa-code-branch"></i></div>
              <span class="service-status">online</span>
            </div>
            <h3>Gitea Forge</h3>
            <p>
              Repository Git, issue tracking e collaborazione tecnica interna. Punto di ingresso
              per codice, review e governance del progetto.
            </p>
            <div class="credential-grid">
              <div class="credential"><span>Endpoint</span><span>${GITEA_URL}</span></div>
              <div class="credential"><span>Root user</span><span>${GITEA_ROOT_USERNAME}</span></div>
              <div class="credential"><span>Password</span><span>${GITEA_ROOT_PASSWORD}</span></div>
              <div class="credential"><span>Email</span><span>${GITEA_ROOT_EMAIL}</span></div>
            </div>
            <div class="card-actions">
              <a class="button" href="${GITEA_URL}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-arrow-up-right-from-square"></i> entra</a>
            </div>
          </article>

          <article class="service-card">
            <div class="service-top">
              <div class="icon-box"><i class="fa-solid fa-diagram-project"></i></div>
              <span class="service-status">guarded</span>
            </div>
            <h3>n8n Automation</h3>
            <p>
              Motore di workflow e integrazione. Ideale per orchestrare webhook, job, pipeline
              applicative e connessioni tra servizi del lab.
            </p>
            <div class="credential-grid">
              <div class="credential"><span>Endpoint</span><span>${N8N_URL}</span></div>
              <div class="credential"><span>Gateway user</span><span>${N8N_GATEWAY_USER}</span></div>
              <div class="credential"><span>Gateway password</span><span>${N8N_GATEWAY_PASSWORD}</span></div>
              <div class="credential"><span>Owner bootstrap</span><span>${N8N_ROOT_FIRST_NAME} ${N8N_ROOT_LAST_NAME}</span></div>
