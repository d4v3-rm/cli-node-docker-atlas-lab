{
  "lab": {
    "name": "Atlas Lab",
    "localUrl": "${LAB_LOCAL_URL}",
    "publicUrl": "${LAB_URL}"
  },
  "features": {
    "aiEnabled": ${ATLAS_AI_ENABLED},
    "imageEnabled": ${ATLAS_IMAGE_ENABLED},
    "workbenchEnabled": ${ATLAS_WORKBENCH_ENABLED}
  },
  "assets": {
    "certificateUrl": "/assets/lab.crt"
  },
  "content": {
    "networkMapPath": "/content/network-map.md"
  },
  "services": {
    "gitea": {
      "url": "${GITEA_URL}",
      "rootUsername": "${GITEA_ROOT_USERNAME}",
      "rootPassword": "${GITEA_ROOT_PASSWORD}",
      "rootEmail": "${GITEA_ROOT_EMAIL}"
    },
    "n8n": {
      "url": "${N8N_URL}",
      "ownerName": "${N8N_ROOT_FIRST_NAME} ${N8N_ROOT_LAST_NAME}",
      "ownerEmail": "${N8N_ROOT_EMAIL}",
      "ownerPassword": "${N8N_ROOT_PASSWORD}"
    },
    "openWebUi": {
      "url": "${OPENWEBUI_URL}",
      "rootName": "${OPENWEBUI_ROOT_NAME}",
      "rootEmail": "${OPENWEBUI_ROOT_EMAIL}",
      "rootPassword": "${OPENWEBUI_ROOT_PASSWORD}"
    },
    "ollama": {
      "url": "${OLLAMA_URL}",
      "gatewayUser": "${OLLAMA_GATEWAY_USER}",
      "gatewayPassword": "${OLLAMA_GATEWAY_PASSWORD}"
    },
    "invokeAi": {
      "url": "${INVOKEAI_URL}",
      "gatewayUser": "${INVOKEAI_GATEWAY_USER}",
      "gatewayPassword": "${INVOKEAI_GATEWAY_PASSWORD}",
      "modelRepo": "${INVOKEAI_MODEL_REPO}",
      "modelRevision": "${INVOKEAI_MODEL_REVISION}",
      "modelTitle": "${INVOKEAI_MODEL_TITLE}",
      "briefingPath": "/content/invokeai.md"
    },
    "swarmUi": {
      "url": "${SWARMUI_URL}",
      "gatewayUser": "${SWARMUI_GATEWAY_USER}",
      "gatewayPassword": "${SWARMUI_GATEWAY_PASSWORD}",
      "modelRepo": "${SWARMUI_MODEL_REPO}",
      "modelRevision": "${SWARMUI_MODEL_REVISION}",
      "modelFile": "${SWARMUI_MODEL_FILE}",
      "modelTitle": "${SWARMUI_MODEL_TITLE}",
      "briefingPath": "/content/swarmui.md"
    }
  },
  "workbenches": {
    "node": {
      "url": "${NODE_DEV_URL}",
      "password": "${NODE_DEV_PASSWORD}",
      "briefingPath": "/content/node-dev.md"
    },
    "python": {
      "url": "${PYTHON_DEV_URL}",
      "password": "${PYTHON_DEV_PASSWORD}",
      "briefingPath": "/content/python-dev.md"
    },
    "ai": {
      "url": "${AI_DEV_URL}",
      "password": "${AI_DEV_PASSWORD}",
      "briefingPath": "/content/ai-dev.md"
    },
    "cpp": {
      "url": "${CPP_DEV_URL}",
      "password": "${CPP_DEV_PASSWORD}",
      "briefingPath": "/content/cpp-dev.md"
    },
    "postgres": {
      "host": "localhost",
      "port": "${POSTGRES_DEV_HOST_PORT}",
      "internalHost": "postgres-dev",
      "internalPort": "5432",
      "database": "${POSTGRES_DEV_DATABASE}",
      "superuser": "${POSTGRES_DEV_SUPERUSER}",
      "password": "${POSTGRES_DEV_PASSWORD}",
      "briefingPath": "/content/postgres-dev.md"
    }
  }
}
