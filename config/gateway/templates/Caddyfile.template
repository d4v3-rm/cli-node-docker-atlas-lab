{
  auto_https disable_redirects
  log {
    output stdout
    format console
    level INFO
  }
  servers {
    protocols h1 h2
  }
}

(lab_tls) {
  tls /etc/caddy/certs/lab.crt /etc/caddy/certs/lab.key
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

(service_proxy) {
  import lab_tls
  reverse_proxy {args[0]}
}

(guarded_proxy) {
  import lab_tls
  basic_auth {
    {args[0]} {args[1]}
  }
  reverse_proxy {args[2]} {
    header_up -Authorization
  }
}

https://${LAB_PUBLIC_HOST}:${LAB_HTTPS_PORT}, https://${LAB_GATEWAY_IP}:${LAB_HTTPS_PORT} {
  import lab_tls
  root * /srv
  try_files {path} /lab-index.html
  file_server
}

https://${LAB_PUBLIC_HOST}:${GITEA_HTTPS_PORT}, https://${LAB_GATEWAY_IP}:${GITEA_HTTPS_PORT} {
  import service_proxy gitea:3000
}

https://${LAB_PUBLIC_HOST}:${N8N_HTTPS_PORT}, https://${LAB_GATEWAY_IP}:${N8N_HTTPS_PORT} {
  import service_proxy n8n:5678
}

https://${LAB_PUBLIC_HOST}:${OPENWEBUI_HTTPS_PORT}, https://${LAB_GATEWAY_IP}:${OPENWEBUI_HTTPS_PORT} {
  import service_proxy open-webui:8080
}

https://${LAB_PUBLIC_HOST}:${OLLAMA_HTTPS_PORT}, https://${LAB_GATEWAY_IP}:${OLLAMA_HTTPS_PORT} {
  import guarded_proxy ${OLLAMA_GATEWAY_USER} ${OLLAMA_GATEWAY_PASSWORD_HASH} ollama:11434
}
