# ------------------------------------------------------------------------------
# Localhost ingress and public endpoints
# ------------------------------------------------------------------------------
LAB_PUBLIC_HOST=localhost
LAB_GATEWAY_IP=127.0.0.1
LAB_HTTPS_PORT=8443
GITEA_HTTPS_PORT=8444
PLANE_HTTPS_PORT=8445
OPENWEBUI_HTTPS_PORT=8446
OLLAMA_HTTPS_PORT=8447
PENPOT_HTTPS_PORT=8448
NEXTCLOUD_AIO_HTTPS_PORT=8449
NODE_DEV_HTTPS_PORT=8450
PYTHON_DEV_HTTPS_PORT=8451
NEXTCLOUD_AIO_SETUP_HTTPS_PORT=8452
LAB_LOCAL_URL=https://localhost:8443/
LAB_URL=https://localhost:8443/
GITEA_URL=https://localhost:8444/
PLANE_URL=https://localhost:8445/
OPENWEBUI_URL=https://localhost:8446/
OLLAMA_URL=https://localhost:8447/
PENPOT_URL=https://localhost:8448/
NEXTCLOUD_AIO_URL=https://localhost:8449/
NODE_DEV_URL=https://localhost:8450/
PYTHON_DEV_URL=https://localhost:8451/
NEXTCLOUD_AIO_SETUP_URL=https://localhost:8452/
TZ=Europe/Rome
APP_VERSION=0.40.5
ATLAS_DOCKER_HUB_MIRRORS=mirror.gcr.io,docker.1ms.run,docker.m.daocloud.io
ATLAS_REGISTRY_PROXIES=docker.m.daocloud.io

# ------------------------------------------------------------------------------
# Gateway TLS and image versions
# ------------------------------------------------------------------------------
SSL_CERT_AUTOGEN=1
SSL_CERT_CN=localhost
SSL_CERT_DAYS=825
CADDY_VERSION=2.11.2-alpine
GITEA_VERSION=1.25.5
GITEA_DB_VERSION=11.4.10
PLANE_APP_RELEASE=stable
OPENWEBUI_VERSION=v0.8.12
OLLAMA_VERSION=0.20.5
PENPOT_VERSION=latest
NEXTCLOUD_AIO_VERSION=latest
POSTGRES_DEV_VERSION=16.13

# ------------------------------------------------------------------------------
# Gitea
# ------------------------------------------------------------------------------
GITEA_UID=1000
GITEA_GID=1000
GITEA_DB_PASSWORD=gitea-db-pass
GITEA_DB_ROOT_PASSWORD=gitea-db-root-pass
GITEA_ROOT_USERNAME=root
GITEA_ROOT_PASSWORD=RootGitea!2026
GITEA_ROOT_EMAIL=root@gitea.local

# ------------------------------------------------------------------------------
# Plane
# ------------------------------------------------------------------------------
PLANE_POSTGRES_USER=plane
PLANE_POSTGRES_PASSWORD=RootPlaneDB!2026
PLANE_POSTGRES_DATABASE=plane
PLANE_RABBITMQ_USER=plane
PLANE_RABBITMQ_PASSWORD=RootPlaneMQ!2026
PLANE_RABBITMQ_VHOST=plane
PLANE_AWS_ACCESS_KEY_ID=plane-access-key
PLANE_AWS_SECRET_ACCESS_KEY=RootPlaneMinIO!2026
PLANE_AWS_S3_BUCKET_NAME=uploads
PLANE_SECRET_KEY=plane-secret-key-atlas-lab-2026
PLANE_LIVE_SERVER_SECRET_KEY=plane-live-secret-key-atlas-lab-2026
PLANE_FILE_SIZE_LIMIT=5242880
PLANE_ROOT_NAME=Root Planner
PLANE_ROOT_EMAIL=root@plane.local
PLANE_ROOT_PASSWORD=RootPlane!2026
PLANE_INSTANCE_NAME=Atlas Lab Plane

# ------------------------------------------------------------------------------
# Open WebUI
# ------------------------------------------------------------------------------
OPENWEBUI_ROOT_NAME=Root Operator
OPENWEBUI_ROOT_EMAIL=root@openwebui.local
OPENWEBUI_ROOT_PASSWORD=RootOpenWebUI!2026
OPENWEBUI_SECRET_KEY=open-webui-secret-key-atlas-lab-2026
OPENWEBUI_CORS_ALLOW_ORIGIN=https://localhost:8443;https://localhost:8446

# ------------------------------------------------------------------------------
# Ollama
# ------------------------------------------------------------------------------
OLLAMA_GPU_REQUEST=all
OLLAMA_NVIDIA_VISIBLE_DEVICES=all
OLLAMA_NVIDIA_DRIVER_CAPABILITIES=compute,utility
OLLAMA_GATEWAY_USER=root
OLLAMA_GATEWAY_PASSWORD=RootOllama!2026
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_RUNTIME_MODELS=qwen3.5:0.8b,qwen3.5:2b,qwen3.5:4b,qwen3.5:9b,qwen3.5:27b,qwen3.5:35b,qwen3.5:122b,gemma4:e2b,gemma4:e4b,gemma4:26b,gemma4:31b,pleasecech/qwen3.6-plus,nomic-embed-text

# ------------------------------------------------------------------------------
# Penpot
# ------------------------------------------------------------------------------
PENPOT_SECRET_KEY=penpot-secret-key-atlas-lab-2026
PENPOT_POSTGRES_PASSWORD=RootPenpotDB!2026
PENPOT_ROOT_NAME=Root Designer
PENPOT_ROOT_EMAIL=root@penpot.local
PENPOT_ROOT_PASSWORD=RootPenpot!2026

# ------------------------------------------------------------------------------
# Nextcloud AIO
# ------------------------------------------------------------------------------
NEXTCLOUD_AIO_MASTER_PORT=18080
NEXTCLOUD_AIO_APACHE_PORT=11000
NEXTCLOUD_AIO_ROOT_USERNAME=root
NEXTCLOUD_AIO_ROOT_PASSWORD=RootNextcloud!2026

# ------------------------------------------------------------------------------
# PostgreSQL development server
# ------------------------------------------------------------------------------
POSTGRES_DEV_SUPERUSER=postgres
POSTGRES_DEV_PASSWORD=RootPostgresDev!2026
POSTGRES_DEV_DATABASE=lab
POSTGRES_DEV_HOST_PORT=15432

# ------------------------------------------------------------------------------
# Node development environment
# ------------------------------------------------------------------------------
NODE_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.115.0
NODE_DEV_NODE_VERSION=20.20.2
NODE_DEV_PNPM_VERSION=10.33.0
NODE_DEV_YARN_VERSION=1.22.22
NODE_DEV_INSTALL_PACKAGES=postgresql-client
NODE_DEV_PASSWORD=RootNodeDev!2026
NODE_DEV_AUTH=password
NODE_DEV_EXTENSIONS=
NODE_DEV_GLOBAL_PACKAGES=

# ------------------------------------------------------------------------------
# Python development environment
# ------------------------------------------------------------------------------
PYTHON_DEV_BASE_IMAGE=ghcr.io/coder/code-server:4.115.0
PYTHON_DEV_PYTHON_VERSION=3.12.13
PYTHON_DEV_INSTALL_PACKAGES=postgresql-client
PYTHON_DEV_PIP_PACKAGES=
PYTHON_DEV_PIP_INDEX_URL=
PYTHON_DEV_PIP_EXTRA_INDEX_URL=
PYTHON_DEV_PASSWORD=RootPythonDev!2026
PYTHON_DEV_AUTH=password
PYTHON_DEV_EXTENSIONS=
PYTHON_DEV_RUNTIME_PIP_PACKAGES=
